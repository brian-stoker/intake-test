# --- Claude via AWS Bedrock ---
# Bedrock bearer token (Bedrock API key). The SDK reads this automatically.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
# Bedrock inference-profile model id. Override to claude-haiku for cheaper/faster.
MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# --- Delivery (the live-swappable axis) ---
# slack | discord | email
DESTINATION=slack
SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=
# RESEND_API_KEY=
# TO_EMAIL=
